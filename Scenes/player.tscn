[sub_resource type="GDScript" id="GDScript_v0iea"]
script/source = "extends Node
var current_state

func change_state(new_state):
	if current_state:
		current_state.exit()
	current_state = new_state
	current_state.enter()

func _physics_process(delta: float) -> void:
	if current_state:
		current_state.update(delta)
"

